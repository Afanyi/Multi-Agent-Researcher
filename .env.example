# Copy to .env and fill in
DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/researcher
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Search API (recommended) - https://serper.dev
SERPER_API_KEY=YOUR_SERPER_KEY

# Optional: restrict by domains by default (comma-separated)
DOMAIN_DEFAULT_ALLOWLIST=kubernetes.io,docs.docker.com,fastapi.tiangolo.com

# Production image namespace for docker-compose.prod.yml
GITHUB_REPO=afanyi/multi-agent-researcher
